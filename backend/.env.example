# Copy to .env and fill in. .env is gitignored.

# Gemini API key with function-calling enabled
GEMINI_API_KEY=

# Render/cloud deployment: paste the full PEM file content here (replaces key file paths)
# OWNER_KEY_CONTENT=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# AGENT_KEY_CONTENT=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Path to proxy_caller.wasm — set to /app/proxy_caller.wasm on Render
# PROXY_WASM=/app/proxy_caller.wasm

# Optional overrides (defaults match the deployed testnet contract in DEPLOYMENT.md)
# NODE_ADDRESS=https://node.testnet.casper.network
# CHAIN_NAME=casper-test
# PACKAGE_HASH=a7d018fcc02bec1a44d1060c6ea77be8869919a91ab4e8f5daf66ecf86acd660
# OWNER_ACCOUNT_HASH=account-hash-104a19bb2e3b5f0db350c28d6941308d33c6134e4eb2fb246cc84b855b054dc3
# AGENT_ACCOUNT_HASH=account-hash-f6bb58c04d779cdbd02c6d89fdcdb24f09eb0dea13bb8a62258990203acf33f3
# PORT=3001
